@model DTO_Integrador.PartidoDTO

@{
    ViewData["Title"] = "Detalle del Partido";
}

<div class="container mt-4">
    <a asp-action="Index" class="btn btn-outline-secondary mb-4">
        ← Volver a las llaves
    </a>

    <div class="card shadow border-0 bg-dark text-white p-4">
        <div class="card-body text-center">

            <span class="badge bg-primary fs-6 mb-3">
                @Model.Fase
            </span>

            <h1 class="fw-bold mb-4">
                @Model.SeleccionLocal
                <span class="text-muted">vs</span>
                @Model.SeleccionVisitante
            </h1>

            @if (!string.IsNullOrEmpty(Model.Estado) && Model.Estado.ToLower() == "finalizado")
            {
                <div class="display-2 fw-bold text-primary mb-3">
                    @Model.GolSeleccion1
                    <span class="text-white">-</span>
                    @Model.GolSeleccion2
                </div>
            }
            else
            {
                <div class="alert alert-warning">
                    Estado: @Model.Estado
                </div>
            }

            <div class="row text-start mt-4">
                <div class="col-md-4 mb-3">
                    <div class="border border-secondary rounded p-3 h-100">
                        <h6 class="text-muted">📍 Estadio</h6>
                        <strong>@Model.Estadio</strong>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="border border-secondary rounded p-3 h-100">
                        <h6 class="text-muted">🗓 Fecha</h6>
                        <strong>@Model.Fecha.ToString("dd/MM/yyyy")</strong>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="border border-secondary rounded p-3 h-100">
                        <h6 class="text-muted">⏰ Hora</h6>
                        <strong>@Model.Hora</strong>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    body {
        background-color: #121418;
        color: #e9ecef;
    }
</style>