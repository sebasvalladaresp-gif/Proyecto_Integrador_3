@model IEnumerable<Modelos_Integrador.FaseDeJuego>

@{
    ViewData["Title"] = "Calendario de Fases";
}

<div class="container mt-4">
    <div class="mb-4 text-center">
        <h1 class="display-5 fw-bold text-primary">
            <i class="bi bi-trophy-fill"></i> Etapas del Torneo
        </h1>
        <p class="text-muted">Consulta el estado actual de las fases competitivas.</p>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover shadow-sm border">
            <thead class="table-dark">
                <tr>
                    <th scope="col"><i class="bi bi-flag"></i> Nombre de la Fase</th>
                    <th scope="col" class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle fw-bold">@item.Nombre</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-search"></i> Ver Detalles
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>