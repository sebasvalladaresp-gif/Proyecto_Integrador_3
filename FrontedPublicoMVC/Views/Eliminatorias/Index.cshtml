@model IEnumerable<IGrouping<string, DTO_Integrador.PartidoDTO>>

@{
    ViewData["Title"] = "Llaves de Eliminatoria";
}

<div class="container-fluid mt-4">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-light"><i class="bi bi-diagram-3-fill"></i> Fase Eliminatoria</h2>
        <p class="text-muted">Cruces y llaves del torneo</p>
    </div>

    <!-- Contenedor general en filas/columnas estilo cuadro de torneo -->
    <div class="bracket-container d-flex overflow-auto pb-4 gap-4">
        @foreach (var faseGroup in Model)
        {
            <div class="bracket-column" style="min-width: 280px; flex: 1;">
                <h5 class="text-center text-info mb-4 fw-bold">@faseGroup.Key</h5>

                <div class="d-flex flex-column gap-3">
                    @foreach (var partido in faseGroup)
                    {
                        <div class="card text-white border-0 shadow-sm rounded-4 p-3" style="background-color: #1e2229;">
                            <!-- Cabecera de la tarjeta (Fecha y Estado) -->
                            <div class="d-flex justify-content-between align-items-center mb-2 text-muted small">
                                <span>@partido.Fecha.ToString("dd/MM") - @partido.Hora.ToString(@"hh\:mm")</span>
                                <span class="badge bg-secondary">@(string.IsNullOrEmpty(partido.Estado) ? "Programado" : partido.Estado)</span>
                            </div>

                            <!-- Seleccion Local -->
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-semibold">@partido.SeleccionLocal</span>
                                <span class="badge bg-dark px-2 py-1">@(partido.GolSeleccion1 ?? 0)</span>
                            </div>

                            <!-- Seleccion Visitante -->
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-semibold">@partido.SeleccionVisitante</span>
                                <span class="badge bg-dark px-2 py-1">@(partido.GolSeleccion2 ?? 0)</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<style>
    body {
        background-color: #121418;
        color: #e9ecef;
    }
    /* Estilo para permitir scroll horizontal si hay muchas fases (Octavos, Cuartos, Semifinal, Final) */
    .bracket-container::-webkit-scrollbar {
        height: 8px;
    }

    .bracket-container::-webkit-scrollbar-thumb {
        background: #2d333b;
        border-radius: 4px;
    }
</style>