@using DTO_Integrador
@model PartidoDTO

@{
    ViewData["Title"] = "Detalle del Partido";
}

<a asp-controller="Calendario" asp-action="Index"
   class="btn btn-outline-secondary mb-4">
    ← Volver al calendario
</a>

<div class="card shadow border-0">
    <div class="card-body text-center p-5">

        <span class="badge bg-primary fs-6 mb-3">
            @Model.Fase
        </span>

        <h1 class="fw-bold mb-4">
            @Model.SeleccionLocal
            <span class="text-muted">vs</span>
            @Model.SeleccionVisitante
        </h1>
      
        @if (Model.Estado == "En curso" || Model.Estado == "Finalizado")
        {
            <div class="display-2 fw-bold text-primary mb-3">
                @Model.GolSeleccion1
                <span class="text-dark">-</span>
                @Model.GolSeleccion2
            </div>
        }
        else if (Model.Estado.ToLower() == "finalizado")
        {
            <div class="display-2 fw-bold text-primary mb-3">
                @Model.GolSeleccion1
                <span class="text-dark">-</span>
                @Model.GolSeleccion2
            </div>
        }
        else if (Model.Estado.ToLower() == "en juego")
        {
            <div class="alert alert-success">
                🔴 El partido se está jugando.
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                ⏳ El partido aún no inicia.
            </div>
        }

        <span class="badge bg-secondary fs-6 px-3 py-2 mb-4">
            Estado: @Model.Estado
        </span>

        <div class="row text-start mt-4">

            <div class="col-md-4 mb-3">
                <div class="border rounded p-3 h-100">
                    <h6 class="text-muted">📍 Estadio</h6>
                    <strong>@Model.Estadio</strong>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="border rounded p-3 h-100">
                    <h6 class="text-muted">🗓 Fecha</h6>
                    <strong>@Model.Fecha.ToString("dd/MM/yyyy")</strong>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="border rounded p-3 h-100">
                    <h6 class="text-muted">⏰ Hora</h6>
                    <strong>@Model.Hora</strong>
                </div>
            </div>

        </div>

    </div>
</div>