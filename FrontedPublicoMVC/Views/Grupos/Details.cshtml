@model DTO_Integrador.GrupoDTO

@{
    ViewData["Title"] = "Detalles del Grupo";
}

<h2>@Model.Name</h2>

<h4 class="mt-4">Tabla de posiciones</h4>

@if (Model.Selecciones == null || !Model.Selecciones.Any())
{
    <p class="text-muted">Todavía no hay selecciones asignadas a este grupo.</p>
}
else
{
    <table class="table table-striped table-hover shadow-sm border">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Selección</th>
                <th class="text-center">PJ</th>
                <th class="text-center">G</th>
                <th class="text-center">E</th>
                <th class="text-center">P</th>
                <th class="text-center">GF</th>
                <th class="text-center">GC</th>
                <th class="text-center">DG</th>
                <th class="text-center">Pts</th>
            </tr>
        </thead>
        <tbody>
            @{
                int posicion = 1;
            }
            @foreach (var s in Model.Selecciones)
            {
                <tr>
                    <td>@posicion</td>
                    <td>@s.nombre</td>
                    <td class="text-center">@s.partidosJugados</td>
                    <td class="text-center">@s.partidosGanados</td>
                    <td class="text-center">@s.partidosEmpatados</td>
                    <td class="text-center">@s.partidosPerdidos</td>
                    <td class="text-center">@s.golesAFavor</td>
                    <td class="text-center">@s.golesEnContra</td>
                    <td class="text-center">@s.diferenciaGoles</td>
                    <td class="text-center fw-bold">@s.puntos</td>
                </tr>
                posicion++;
            }
        </tbody>
    </table>
}

<p>
    <a asp-action="Index">Volver a la lista</a>
</p>
