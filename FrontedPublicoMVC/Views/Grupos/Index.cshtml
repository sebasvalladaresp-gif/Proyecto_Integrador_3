@model IEnumerable<DTO_Integrador.GrupoDTO>

@{
    ViewData["Title"] = "Grupos del Torneo";
}

<div class="container mt-4">
    <div class="mb-4 text-center">
        <h1 class="display-5 fw-bold text-primary">
            <i class="bi bi-people-fill"></i> Clasificación por Grupos
        </h1>
        <p class="text-muted">Visualiza los equipos organizados por grupos de competencia.</p>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover shadow-sm border">
            <thead class="table-dark">
                <tr>
                    <th scope="col"><i class="bi bi-people"></i> Nombre del Grupo</th>
                    <th scope="col" class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle fw-bold">@item.Name</td>
                        <td class="text-end">
                            @* Requiere que GrupoDTO tenga la propiedad Id *@
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-search"></i> Ver Integrantes
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
